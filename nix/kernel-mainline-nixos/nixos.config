# Kernel options NixOS 25.05 / systemd require on top of sun8i_v536_defconfig
# (see nixos/modules/system/boot/systemd.nix system.requiredKernelConfig).
# The defconfig already provides DEVTMPFS, CGROUPS, NET, EXT4, AUTOFS_FS,
# TMPFS_POSIX_ACL, CRYPTO_USER_API_HASH and NLS codepages; INOTIFY_USER,
# SIGNALFD, TIMERFD, EPOLL, SYSFS, PROC_FS, FHANDLE and SECCOMP default to y.
# CONFIG_DMIID is not selectable on arm32 (needs EFI/DMI) and systemd copes
# without it. The image boots without an initrd (boot.initrd.enable = false),
# so BLK_DEV_INITRD stays off.

# systemd: hashed credentials / journal sealing / machine-id
CONFIG_CRYPTO_HMAC=y
CONFIG_CRYPTO_SHA256=y

# systemd-tmpfiles and PrivateTmp need xattrs on tmpfs
CONFIG_TMPFS_XATTR=y

# namespaces for systemd sandboxing (USER_NS already in the defconfig)
CONFIG_NAMESPACES=y
CONFIG_UTS_NS=y
CONFIG_IPC_NS=y
CONFIG_PID_NS=y
CONFIG_NET_NS=y

# ACLs / security xattrs on the ext4 root (journald, /var/log ACLs)
CONFIG_EXT4_FS_POSIX_ACL=y
CONFIG_EXT4_FS_SECURITY=y

# loop devices (squashfs/disk image mounting from userspace)
CONFIG_BLK_DEV_LOOP=y

# /proc/config.gz for debugging the running kernel
CONFIG_IKCONFIG=y
CONFIG_IKCONFIG_PROC=y

# Wireless stack for a future out-of-tree xradio (XR819) driver; the board
# defconfig stays lean because mainline has no driver for this chip.
CONFIG_CFG80211=y
CONFIG_MAC80211=y
